---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n/translations';

const locale = 'en';
const tr = t(locale);
---

<BaseLayout locale={locale} title={tr.ecosystem.title} description={tr.ecosystem.intro} navCurrent="ecosystem">
  <h1 class="page-title">{tr.ecosystem.title}</h1>
  <p class="page-intro">{tr.ecosystem.intro}</p>

  <section class="section">
    <h2>{tr.ecosystem.explorersTitle}</h2>
    <div class="cards">
      {tr.ecosystem.explorers.map(({ name, desc, url }) => (
        <article class="card">
          <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}</h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.ecosystem.walletsTitle}</h2>
    <div class="cards">
      {tr.ecosystem.wallets.map(({ name, desc, url }) => (
        <article class="card">
          <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}</h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.ecosystem.dexTitle}</h2>
    <div class="cards">
      {tr.ecosystem.dexes.map(({ name, desc, url }) => (
        <article class="card">
          <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}</h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.ecosystem.paymentsTitle}</h2>
    <div class="cards">
      {tr.ecosystem.payments.map(({ name, desc, url }) => (
        <article class="card">
          <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}</h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.ecosystem.infraTitle}</h2>
    <div class="cards">
      {tr.ecosystem.infra.map(({ name, desc, url }) => (
        <article class="card">
          <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}</h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.ecosystem.namingTitle}</h2>
    <div class="cards">
      {tr.ecosystem.naming.map(({ name, desc, url }) => (
        <article class="card">
          <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}</h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.ecosystem.earnTitle}</h2>
    <div class="cards">
      {tr.ecosystem.earn.map(({ name, desc, url }) => (
        <article class="card">
          <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}</h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.ecosystem.institutionalTitle}</h2>
    <div class="cards">
      {tr.ecosystem.institutional.map(({ name, desc, url }) => (
        <article class="card">
          <h3>{url ? <a href={url} target="_blank" rel="noopener noreferrer">{name}</a> : name}</h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <p class="full-list-link">
    <a href={tr.ecosystem.fullListUrl} target="_blank" rel="noopener noreferrer">
      {tr.ecosystem.fullListNote}
    </a>
  </p>
</BaseLayout>
