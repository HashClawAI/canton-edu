---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n/translations';

const locale = 'zh';
const tr = t(locale);
---

<BaseLayout locale={locale} title={tr.research.title} description={tr.research.intro} navCurrent="research">
  <h1 class="page-title">{tr.research.title}</h1>
  <p class="page-intro">{tr.research.intro}</p>

  <section class="section">
    <h2>{tr.research.institutionalTitle}</h2>
    <div class="report-list">
      {tr.research.institutional.map(({ source, title, date, desc, url }) => (
        <article class="report-item">
          <div class="report-meta">
            <span class="report-source">{source}</span>
            <time>{date}</time>
          </div>
          <h3><a href={url} target="_blank" rel="noopener noreferrer">{title}</a></h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.research.tieTitle}</h2>
    <p class="page-intro">{tr.research.tieIntro}</p>
    <ol class="steps">
      {tr.research.tieParts.map(({ part, title, date, url }) => (
        <li>
          <strong><a href={url} target="_blank" rel="noopener noreferrer">{part}: {title}</a></strong>
          {date && <span>{date}</span>}
        </li>
      ))}
    </ol>
  </section>

  <section class="section">
    <h2>{tr.research.daicTitle}</h2>
    <p class="page-intro">{tr.research.daicIntro}</p>
    <ul class="resource-list">
      {tr.research.daicParts.map(({ title, url }) => (
        <li><a href={url} target="_blank" rel="noopener noreferrer">{title}</a></li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2>{tr.research.officialTitle}</h2>
    <ul class="resource-list">
      {tr.research.officialParts.map(({ title, url }) => (
        <li><a href={url} target="_blank" rel="noopener noreferrer">{title}</a></li>
      ))}
    </ul>
  </section>
</BaseLayout>
