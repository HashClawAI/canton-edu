---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n/translations';

const locale = 'zh';
const tr = t(locale);
const base = import.meta.env.BASE_URL;
---

<BaseLayout locale={locale} title={tr.community.title} description={tr.community.intro} navCurrent="community">
  <h1 class="page-title">{tr.community.title}</h1>
  <p class="page-intro">{tr.community.intro}</p>

  <section class="section">
    <h2>{tr.community.discordTitle}</h2>
    <p>{tr.community.discordBody}</p>
    <a class="btn btn-primary" href={tr.community.discordUrl} target="_blank" rel="noopener noreferrer">
      加入 Discord ↗
    </a>
  </section>

  <section class="section">
    <h2>{tr.community.telegramTitle}</h2>
    <p class="page-intro">{tr.community.telegramIntro}</p>
    <ul class="resource-list">
      {tr.community.telegramGroups.map(({ name, desc, url }) => (
        <li>
          <a href={url} target="_blank" rel="noopener noreferrer">{name}</a>
          {' — '}
          <span class="inline-muted">{desc}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2>{tr.community.forumsTitle}</h2>
    <p class="page-intro">{tr.community.forumsIntro}</p>
    <div class="cards">
      {tr.community.forums.map(({ name, desc, url }) => (
        <article class="card">
          <h3><a href={url} target="_blank" rel="noopener noreferrer">{name}</a></h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.community.twitterTitle}</h2>
    <div class="cards cards-3">
      {tr.community.twitterAccounts.map(({ name, desc, url }) => (
        <article class="card">
          <h3><a href={url} target="_blank" rel="noopener noreferrer">{name}</a></h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>{tr.community.governanceTitle}</h2>
    <p>{tr.community.governanceBody}</p>
    <ul class="resource-list">
      {tr.community.governanceLinks.map(({ name, url }) => (
        <li><a href={url} target="_blank" rel="noopener noreferrer">{name} ↗</a></li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2>{tr.community.devFundTitle}</h2>
    <p>{tr.community.devFundBody}</p>
    <a class="btn btn-secondary" href={tr.community.devFundUrl} target="_blank" rel="noopener noreferrer">
      了解更多 ↗
    </a>
  </section>

  <p class="disclaimer">
    {tr.community.seeNewsNote} <a href={`${base}zh/news`}>动态 →</a>
    {' · '}
    <a href={`${base}zh/resources`}>资源 →</a>
  </p>

  <section class="section">
    <h2>{tr.community.wikiTitle}</h2>
    <div class="cards">
      {tr.community.wikiLinks.map(({ name, url, desc }) => (
        <article class="card">
          <h3><a href={url} target="_blank" rel="noopener noreferrer">{name}</a></h3>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
