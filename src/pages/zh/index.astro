---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n/translations';
import CoinPrice from '@/components/CoinPrice.astro';
import SiteLogo from '@/components/SiteLogo.astro';

const locale = 'zh';
const tr = t(locale);
const base = import.meta.env.BASE_URL;
---

<BaseLayout locale={locale} title={tr.home.title} description={tr.home.subtitle} navCurrent="home">
  <section class="hero">
    <div class="hero-logo-wrap" aria-hidden="true">
      <SiteLogo variant="hero" alt="" />
    </div>
    <h1>{tr.home.title}</h1>
    <p class="lead">{tr.home.subtitle}</p>
    <div class="actions">
      <a class="btn btn-primary" href={`${base}zh/learn`}>{tr.home.ctaLearn}</a>
      <a class="btn btn-secondary" href={`${base}zh/ecosystem`}>{tr.home.ctaEcosystem}</a>
    </div>
    <CoinPrice
      locale="zh"
      bitcoinLabel={tr.home.coinPriceBitcoinLabel}
      ccLabel={tr.home.coinPriceCcLabel}
      ccBtcLabel={tr.home.coinPriceCcBtcLabel}
      ccBtcFootnote={tr.home.coinPriceCcBtcFootnote}
      satPerCcUnit={tr.home.coinPriceSatPerCcUnit}
      chartTitle={tr.home.coinPriceChartTitle}
      chartSubtitle={tr.home.coinPriceChartSubtitle}
      chartBuildHint={tr.home.coinPriceChartBuildHint}
    />
  </section>
  <div class="cards cards-4">
    <article class="card">
      <h2>{tr.home.cardWhatTitle}</h2>
      <p>{tr.home.cardWhatBody}</p>
    </article>
    <article class="card">
      <h2>{tr.home.cardWhoTitle}</h2>
      <p>{tr.home.cardWhoBody}</p>
    </article>
    <article class="card">
      <h2>{tr.home.cardCIPTitle}</h2>
      <p>{tr.home.cardCIPBody}</p>
    </article>
    <article class="card">
      <h2>{tr.home.cardCommunityTitle}</h2>
      <p>{tr.home.cardCommunityBody}</p>
    </article>
  </div>

  <section class="build-sync-section" aria-labelledby="build-sync-heading">
    <h2 id="build-sync-heading">{tr.home.buildSyncTitle}</h2>
    <p class="build-sync-intro">{tr.home.buildSyncIntro}</p>
    <ul class="build-sync-list">
      {tr.home.buildSyncItems.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="contribute-section">
    <h2>{tr.home.contributeTitle}</h2>
    <p>{tr.home.contributeBody}</p>
    <a class="btn btn-secondary" href={tr.home.contributeRepo} target="_blank" rel="noopener noreferrer">
      {tr.home.contributeRepoLabel} ↗
    </a>

    <div class="contribute-install">
      <p class="contribute-label">{tr.home.contributeInstallLabel}</p>
      <code class="command-item install-cmd">{tr.home.contributeInstallCmd}</code>
      <p class="contribute-note">{tr.home.contributeInstallNote}</p>
    </div>

    <div class="contribute-commands">
      <p class="contribute-label">{tr.home.contributeCommandsLabel}</p>
      <div class="command-list">
        {tr.home.contributeCommands.map((cmd) => (
          <code class="command-item">{cmd}</code>
        ))}
      </div>
    </div>

    <div class="contribute-manual">
      <p class="contribute-label">{tr.home.contributeManualLabel}</p>
      <code class="command-item">{tr.home.contributeManualSteps}</code>
    </div>
  </section>
</BaseLayout>
