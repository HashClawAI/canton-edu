---
interface Props {
  /** Header nav mark vs home hero */
  variant?: 'header' | 'hero';
  alt?: string;
}

const { variant = 'header', alt = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
const src = `${base}hashclaw-logo.png`;
const hero = variant === 'hero';
---

<img
  class:list={[hero ? 'hero-logo' : 'brand-logo']}
  src={src}
  width={hero ? 140 : 40}
  height={hero ? 140 : 40}
  alt={alt}
  decoding="async"
  fetchpriority={hero ? 'auto' : 'high'}
/>
