---
interface Props {
  locale?: 'en' | 'zh';
  bitcoinLabel: string;
  ccLabel: string;
  ccBtcLabel: string;
  ccBtcFootnote: string;
  satPerCcUnit: string;
  chartTitle: string;
  chartSubtitle: string;
}

const {
  locale = 'en',
  bitcoinLabel,
  ccLabel,
  ccBtcLabel,
  ccBtcFootnote,
  satPerCcUnit,
  chartTitle,
  chartSubtitle,
} = Astro.props;
const loc = locale === 'zh' ? 'zh-CN' : 'en-US';
---

<div class="coin-ticker" id="coin-ticker" data-locale={loc}>
  <div class="coin-block">
    <div class="coin-row">
      <span class="coin-label">{bitcoinLabel}</span>
      <span class="coin-price" id="btc-price">--</span>
      <span class="coin-change" id="btc-change"></span>
    </div>
    <div class="coin-row">
      <span class="coin-label">{ccLabel}</span>
      <span class="coin-price" id="cc-price">--</span>
      <span class="coin-change" id="cc-change"></span>
      <span class="coin-extra" id="cc-extra"></span>
    </div>
    <div class="coin-row coin-row-pair">
      <span class="coin-label coin-label-muted">{ccBtcLabel}</span>
      <span class="coin-pair-wrap" id="ccbtc-wrap">
        <span class="coin-pair-prefix" id="ccbtc-prefix"></span>
        <span class="coin-pair-value" id="ccbtc-value">--</span>
        <span class="coin-pair-unit">{satPerCcUnit}</span>
      </span>
    </div>
    <p class="coin-footnote">{ccBtcFootnote}</p>
  </div>

  <div
    class="coin-chart"
    id="coin-chart"
    hidden
    data-range-label={locale === 'zh' ? '24 小时' : '24h'}
  >
    <div class="coin-chart-head">
      <span class="coin-chart-title">{chartTitle}</span>
      <span class="coin-chart-sub">{chartSubtitle}</span>
    </div>
    <svg
      class="coin-chart-svg"
      id="coin-chart-svg"
      viewBox="0 0 420 132"
      preserveAspectRatio="none"
      role="img"
      aria-labelledby="coin-chart-aria-title"
    >
      <title id="coin-chart-aria-title">{chartTitle}</title>
      <defs>
        <linearGradient id="coin-chart-fill" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#3d8bfd" stop-opacity="0.28"></stop>
          <stop offset="100%" stop-color="#3d8bfd" stop-opacity="0"></stop>
        </linearGradient>
      </defs>
      <path id="coin-chart-area" class="coin-chart-area" d="" fill="url(#coin-chart-fill)"></path>
      <path id="coin-chart-line" class="coin-chart-line" d="" fill="none"></path>
    </svg>
    <div class="coin-chart-axis" id="coin-chart-axis" aria-hidden="true"></div>
  </div>
</div>

<script>
  const API =
    'https://api.coingecko.com/api/v3/simple/price?ids=canton-network,bitcoin&vs_currencies=usd&include_24hr_change=true&include_market_cap=true&include_24hr_vol=true';
  const CHART_CC =
    'https://api.coingecko.com/api/v3/coins/canton-network/market_chart?vs_currency=usd&days=1';
  const CHART_BTC =
    'https://api.coingecko.com/api/v3/coins/bitcoin/market_chart?vs_currency=usd&days=1';

  const W = 420;
  const H = 132;
  const PAD = { t: 14, r: 10, b: 22, l: 10 };
  const IW = W - PAD.l - PAD.r;
  const IH = H - PAD.t - PAD.b;

  function fmtUsdLarge(n: number): string {
    return (
      '$' +
      n.toLocaleString(undefined, {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      })
    );
  }

  function formatSatsPerCc(sats: number, btcPerCc: number, localeTag: string): { prefix: string; value: string } {
    if (!Number.isFinite(sats) || sats <= 0 || !Number.isFinite(btcPerCc) || btcPerCc <= 0) {
      return { prefix: '', value: '--' };
    }
    const prefix = '≈ ';
    if (sats >= 0.01) {
      return {
        prefix,
        value: sats.toLocaleString(localeTag, { maximumFractionDigits: 4, minimumFractionDigits: 2 }),
      };
    }
    if (sats >= 1e-6) {
      return { prefix, value: sats.toFixed(8).replace(/\.?0+$/, '') || '0' };
    }
    return {
      prefix,
      value: `${sats.toExponential(3)} (${btcPerCc.toExponential(3)} BTC)`,
    };
  }

  function fmt(n: number): string {
    if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';
    if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';
    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
    return n.toFixed(0);
  }

  type Pt = [number, number];

  function sortByTime(pairs: Pt[]): Pt[] {
    return [...pairs].sort((a, b) => a[0] - b[0]);
  }

  function interpolateY(points: Pt[], x: number): number | null {
    if (points.length === 0) return null;
    if (x <= points[0][0]) return points[0][1];
    const last = points[points.length - 1];
    if (x >= last[0]) return last[1];
    let lo = 0;
    let hi = points.length - 1;
    while (hi - lo > 1) {
      const mid = (lo + hi) >> 1;
      if (points[mid][0] <= x) lo = mid;
      else hi = mid;
    }
    const [x0, y0] = points[lo];
    const [x1, y1] = points[hi];
    if (x1 <= x0) return y0;
    return y0 + ((x - x0) / (x1 - x0)) * (y1 - y0);
  }

  function emaSeries(values: number[], alpha: number): number[] {
    const out: number[] = [];
    let e = values[0];
    for (const v of values) {
      e = alpha * v + (1 - alpha) * e;
      out.push(e);
    }
    return out;
  }

  function buildSatsSeries(ccPrices: Pt[], btcPrices: Pt[]): { t: number; sats: number }[] {
    const cc = sortByTime(ccPrices);
    const btc = sortByTime(btcPrices);
    const out: { t: number; sats: number }[] = [];
    for (const [t, ccUsd] of cc) {
      if (typeof ccUsd !== 'number' || ccUsd <= 0) continue;
      const btcUsd = interpolateY(btc, t);
      if (btcUsd == null || btcUsd <= 0) continue;
      out.push({ t, sats: (ccUsd / btcUsd) * 1e8 });
    }
    return out;
  }

  function smoothCurve(sats: number[]): number[] {
    const a = 0.16;
    const b = 0.22;
    return emaSeries(emaSeries(sats, a), b);
  }

  function toPath(ys: number[], ymin: number, ymax: number): { line: string; area: string } {
    if (ys.length < 2) return { line: '', area: '' };
    const xScale = (i: number) => PAD.l + (i / (ys.length - 1)) * IW;
    const yScale = (v: number) => {
      const span = ymax - ymin || 1;
      const n = (v - ymin) / span;
      return PAD.t + (1 - n) * IH;
    };
    const pts = ys.map((_, i) => [xScale(i), yScale(ys[i])] as const);
    let d = `M ${pts[0][0].toFixed(1)} ${pts[0][1].toFixed(1)}`;
    for (let i = 1; i < pts.length; i++) {
      d += ` L ${pts[i][0].toFixed(1)} ${pts[i][1].toFixed(1)}`;
    }
    const y0 = PAD.t + IH;
    const area = `${d} L ${pts[pts.length - 1][0].toFixed(1)} ${y0} L ${pts[0][0].toFixed(1)} ${y0} Z`;
    return { line: d, area };
  }

  async function fetchChart(): Promise<void> {
    const wrap = document.getElementById('coin-chart');
    const root = document.getElementById('coin-ticker');
    const localeTag = root?.dataset.locale || 'en-US';
    const lineEl = document.getElementById('coin-chart-line');
    const areaEl = document.getElementById('coin-chart-area');
    const axisEl = document.getElementById('coin-chart-axis');
    if (!wrap || !lineEl || !areaEl || !axisEl) return;

    try {
      const [rCc, rBtc] = await Promise.all([fetch(CHART_CC), fetch(CHART_BTC)]);
      if (!rCc.ok || !rBtc.ok) return;
      const jCc = (await rCc.json()) as { prices?: Pt[] };
      const jBtc = (await rBtc.json()) as { prices?: Pt[] };
      const ccP = jCc.prices;
      const btcP = jBtc.prices;
      if (!Array.isArray(ccP) || !Array.isArray(btcP) || ccP.length < 8 || btcP.length < 8) return;

      const series = buildSatsSeries(ccP, btcP);
      if (series.length < 8) return;

      const raw = series.map((s) => s.sats);
      const smoothed = smoothCurve(raw);
    let ymin = Math.min(...smoothed);
    let ymax = Math.max(...smoothed);
    const pad = (ymax - ymin) * 0.08 || ymin * 0.002;
    ymin -= pad;
    ymax += pad;

      const { line, area } = toPath(smoothed, ymin, ymax);
      lineEl.setAttribute('d', line);
      areaEl.setAttribute('d', area);

      const rangeLabel = wrap.dataset.rangeLabel || '24h';
      const fmtLo = smoothed[0].toLocaleString(localeTag, { maximumFractionDigits: 2, minimumFractionDigits: 2 });
      const fmtHi = smoothed[smoothed.length - 1].toLocaleString(localeTag, {
        maximumFractionDigits: 2,
        minimumFractionDigits: 2,
      });
      const minStr = Math.min(...smoothed).toLocaleString(localeTag, { maximumFractionDigits: 2 });
      const maxStr = Math.max(...smoothed).toLocaleString(localeTag, { maximumFractionDigits: 2 });
      axisEl.textContent = `${minStr} — ${maxStr} · ${rangeLabel}: ${fmtLo} → ${fmtHi}`;

      wrap.hidden = false;
    } catch {
      /* silent */
    }
  }

  async function fetchPrice() {
    const root = document.getElementById('coin-ticker');
    const localeTag = root?.dataset.locale || 'en-US';

    const btcPriceEl = document.getElementById('btc-price');
    const btcChangeEl = document.getElementById('btc-change');
    const ccPriceEl = document.getElementById('cc-price');
    const ccChangeEl = document.getElementById('cc-change');
    const ccExtraEl = document.getElementById('cc-extra');
    const ccbtcPrefixEl = document.getElementById('ccbtc-prefix');
    const ccbtcValueEl = document.getElementById('ccbtc-value');
    if (!btcPriceEl || !btcChangeEl || !ccPriceEl || !ccChangeEl || !ccExtraEl || !ccbtcPrefixEl || !ccbtcValueEl) return;

    try {
      const res = await fetch(API);
      if (!res.ok) return;
      const data = await res.json();
      const cc = data['canton-network'];
      const btc = data['bitcoin'];
      if (!cc || !btc) return;

      const ccUsd = cc.usd;
      const btcUsd = btc.usd;
      if (typeof ccUsd !== 'number' || typeof btcUsd !== 'number' || btcUsd <= 0) return;

      btcPriceEl.textContent = fmtUsdLarge(btcUsd);
      const btcChg = btc.usd_24h_change;
      if (btcChg !== undefined && btcChg !== null) {
        const sign = btcChg >= 0 ? '+' : '';
        btcChangeEl.textContent = `${sign}${btcChg.toFixed(2)}%`;
        btcChangeEl.classList.remove('up', 'down');
        btcChangeEl.classList.add(btcChg >= 0 ? 'up' : 'down');
      } else {
        btcChangeEl.textContent = '';
        btcChangeEl.classList.remove('up', 'down');
      }

      ccPriceEl.textContent = `$${ccUsd.toFixed(4)}`;
      const change = cc.usd_24h_change;
      if (change !== undefined && change !== null) {
        const sign = change >= 0 ? '+' : '';
        ccChangeEl.textContent = `${sign}${change.toFixed(2)}%`;
        ccChangeEl.classList.remove('up', 'down');
        ccChangeEl.classList.add(change >= 0 ? 'up' : 'down');
      } else {
        ccChangeEl.textContent = '';
        ccChangeEl.classList.remove('up', 'down');
      }

      const parts: string[] = [];
      const mcap = cc.usd_market_cap;
      const vol = cc.usd_24h_vol;
      if (mcap) parts.push(`MCap $${fmt(mcap)}`);
      if (vol) parts.push(`Vol $${fmt(vol)}`);
      ccExtraEl.textContent = parts.length ? parts.join(' · ') : '';

      const btcPerCc = ccUsd / btcUsd;
      const satsPerCc = btcPerCc * 1e8;
      const { prefix, value } = formatSatsPerCc(satsPerCc, btcPerCc, localeTag);
      ccbtcPrefixEl.textContent = prefix;
      ccbtcValueEl.textContent = value;
    } catch {
      /* silent */
    }
  }

  fetchPrice();
  setInterval(fetchPrice, 60_000);
  fetchChart();
  setInterval(fetchChart, 300_000);
</script>

<style>
  .coin-ticker {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.65rem 1rem 0.55rem;
    font-size: 0.95rem;
    margin-top: 1.5rem;
    max-width: 36rem;
  }

  .coin-block {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .coin-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .coin-row-pair {
    padding-top: 0.25rem;
    border-top: 1px solid var(--border);
    font-size: 0.88rem;
  }

  .coin-label {
    font-weight: 600;
    color: var(--text);
  }

  .coin-label-muted {
    font-weight: 600;
    color: var(--muted);
  }

  .coin-price {
    font-weight: 700;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .coin-change {
    font-size: 0.88rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .coin-change.up {
    color: #4ade80;
  }

  .coin-change.down {
    color: #f87171;
  }

  .coin-extra {
    font-size: 0.82rem;
    color: var(--muted);
    width: 100%;
    flex-basis: 100%;
  }

  .coin-pair-wrap {
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.25rem;
    font-variant-numeric: tabular-nums;
    color: var(--muted);
  }

  .coin-pair-prefix {
    color: var(--muted);
  }

  .coin-pair-value {
    font-weight: 600;
    color: var(--text);
  }

  .coin-pair-unit {
    color: var(--muted);
    font-size: 0.85em;
  }

  .coin-footnote {
    margin: 0.15rem 0 0;
    font-size: 0.75rem;
    line-height: 1.35;
    color: var(--muted);
  }

  .coin-chart {
    margin-top: 0.85rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .coin-chart-head {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.45rem;
  }

  .coin-chart-title {
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--text);
  }

  .coin-chart-sub {
    font-size: 0.72rem;
    line-height: 1.35;
    color: var(--muted);
  }

  .coin-chart-svg {
    display: block;
    width: 100%;
    height: 140px;
    overflow: visible;
  }

  .coin-chart-line {
    stroke: var(--accent);
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .coin-chart-area {
    stroke: none;
  }

  .coin-chart-axis {
    margin-top: 0.35rem;
    font-size: 0.7rem;
    line-height: 1.35;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
</style>
