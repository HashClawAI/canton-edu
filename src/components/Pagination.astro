---
import type { Locale } from '@/i18n/translations';
import { t } from '@/i18n/translations';
import { newsListHref } from '@/lib/newsPagination';

interface Props {
  locale: Locale;
  currentPage: number;
  totalPages: number;
}

const { locale, currentPage, totalPages } = Astro.props;
const base = import.meta.env.BASE_URL;
const tr = t(locale);

if (totalPages <= 1) {
  return null;
}

const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
const prevHref = newsListHref(locale, currentPage - 1, base);
const nextHref = newsListHref(locale, currentPage + 1, base);
---

<nav class="pagination" aria-label={tr.news.paginationNavLabel}>
  {
    hasPrev ? (
      <a class="pagination-step" href={prevHref}>
        {tr.news.paginationPrev}
      </a>
    ) : (
      <span class="pagination-step is-disabled" aria-disabled="true">
        {tr.news.paginationPrev}
      </span>
    )
  }
  <ul class="pagination-pages">
    {
      pages.map((p) => (
        <li>
          {p === currentPage ? (
            <span class="pagination-current" aria-current="page">
              {p}
            </span>
          ) : (
            <a class="pagination-link" href={newsListHref(locale, p, base)}>
              {p}
            </a>
          )}
        </li>
      ))
    }
  </ul>
  {
    hasNext ? (
      <a class="pagination-step" href={nextHref}>
        {tr.news.paginationNext}
      </a>
    ) : (
      <span class="pagination-step is-disabled" aria-disabled="true">
        {tr.news.paginationNext}
      </span>
    )
  }
</nav>
